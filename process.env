# Runtime-layer launcher state hardening defaults
#
# These keys are read directly from process.env by the CLI runtime launcher.
# Keep this file as a minimal reference for the hardening behavior.

# 1/true (default): on stale/missing launcher state path errors, retry once
# with a stable provider home path.
DISCOCLAW_CLI_LAUNCHER_STATE_HARDENING=1

# Optional override for the Codex stable home used during the retry attempt.
# If unset, DiscoClaw defaults to: <process.cwd()>/.codex-home-discoclaw
#DISCOCLAW_CODEX_STABLE_HOME=/absolute/path/to/.codex-home-discoclaw
