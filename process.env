# Runtime-layer launcher state hardening defaults
#
# These keys are read directly from process.env by the CLI runtime launcher.
# Keep this file as a minimal reference for the hardening behavior.

# 1/true (default): on stale/missing launcher state path errors, retry once
# with a stable provider home path.
DISCOCLAW_CLI_LAUNCHER_STATE_HARDENING=1

# Optional override for the Codex stable home used during the retry attempt.
# If unset, DiscoClaw defaults to: <process.cwd()>/.codex-home-discoclaw
#DISCOCLAW_CODEX_STABLE_HOME=/absolute/path/to/.codex-home-discoclaw

# Optional: Codex app-server websocket URL for the native runtime path.
# When paired with CODEX_APP_SERVER_NATIVE=1, DiscoClaw uses the websocket
# app-server as the primary transport for thread creation, turn starts,
# streaming output, steering, and interrupts.
# Leave unset to keep using the legacy codex CLI transport only.
#CODEX_APP_SERVER_URL=ws://127.0.0.1:4321
# Enable native Codex app-server turn creation over the websocket transport.
# Set to 1 to make the app-server the primary path for eligible turns. Image turns,
# non-default cwd turns, non-empty addDirs, and websocket bootstrap failures
# fall back to codex exec automatically.
#CODEX_APP_SERVER_NATIVE=0
